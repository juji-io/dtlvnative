#!/bin/sh

set -eou pipefail

ROOT_DIR=$(
  CDPATH= cd -- "$(dirname "$0")/.." && pwd
)

cleanup() {
  "$ROOT_DIR/script/llama-embed-only-patch.sh" revert >/dev/null 2>&1 || true
}

trap cleanup EXIT

"$ROOT_DIR/script/llama-embed-only-patch.sh" apply

export SOEXT=.so

rewrite_usearch_arch_flags() {
    build_dir=$1
    replacement=$2
    [ -n "$replacement" ] || return 0

    flags_files=$(find "$build_dir" \( -name flags.make -o -name build.ninja \) -print)
    if [ -z "$flags_files" ]; then
        echo "No usearch build flag files found under $build_dir" >&2
        exit 1
    fi

    for flags_file in $flags_files; do
        perl -0pi -e "s/-march=native/$replacement/g" "$flags_file"
    done

    if grep -R -- '-march=native' "$build_dir" >/dev/null 2>&1; then
        echo "usearch build still contains -march=native after baseline rewrite" >&2
        exit 1
    fi
}

# build usearch

cd src/usearch

# Copied from linux build file
ARCH_FLAGS=""
SIMSIMD_X86_FLAGS=""
if [ "$(uname -m)" = "amd64" ]; then
    ARCH_FLAGS="-march=x86-64-v3"
    SIMSIMD_X86_FLAGS="-D SIMSIMD_TARGET_HASWELL=1 \
    -D SIMSIMD_TARGET_SKYLAKE=0 \
    -D SIMSIMD_TARGET_ICE=0 \
    -D SIMSIMD_TARGET_GENOA=0 \
    -D SIMSIMD_TARGET_SAPPHIRE=0 \
    -D SIMSIMD_TARGET_TURIN=0 \
    -D SIMSIMD_TARGET_SIERRA=0"
fi

cmake \
    -D CMAKE_BUILD_TYPE=Release \
    ${ARCH_FLAGS:+-D CMAKE_CXX_FLAGS="$ARCH_FLAGS"} \
    ${ARCH_FLAGS:+-D CMAKE_C_FLAGS="$ARCH_FLAGS"} \
    ${SIMSIMD_X86_FLAGS:+$SIMSIMD_X86_FLAGS} \
    -D USEARCH_USE_FP16LIB=1 \
    -D USEARCH_USE_OPENMP=1 \
    -D USEARCH_USE_SIMSIMD=1 \
    -D USEARCH_BUILD_TEST_CPP=1 \
    -D USEARCH_BUILD_TEST_C=1 \
    -D USEARCH_BUILD_LIB_C=1 \
    -B build_release

rewrite_usearch_arch_flags build_release "$ARCH_FLAGS"

cmake --build build_release --config Release

build_release/test_cpp
build_release/test_c

# build llama.cpp

cd ../llama.cpp

cmake \
    -D CMAKE_BUILD_TYPE=Release \
    -D CMAKE_POSITION_INDEPENDENT_CODE=ON \
    -D BUILD_SHARED_LIBS=OFF \
    -D LLAMA_OPENSSL=OFF \
    -D GGML_CPU=ON \
    -D GGML_OPENMP=ON \
    -D GGML_NATIVE=OFF \
    -D GGML_LLAMAFILE=OFF \
    -D GGML_CPU_REPACK=OFF \
    -D GGML_BACKEND_DL=OFF \
    -D GGML_ACCELERATE=OFF \
    -D GGML_BLAS=OFF \
    -D GGML_CUDA=OFF \
    -D GGML_HIP=OFF \
    -D GGML_METAL=OFF \
    -D GGML_MUSA=OFF \
    -D GGML_OPENCL=OFF \
    -D GGML_RPC=OFF \
    -D GGML_SYCL=OFF \
    -D GGML_VULKAN=OFF \
    -D GGML_WEBGPU=OFF \
    -D LLAMA_BUILD_COMMON=OFF \
    -D LLAMA_BUILD_TESTS=OFF \
    -D LLAMA_BUILD_TOOLS=OFF \
    -D LLAMA_BUILD_EXAMPLES=OFF \
    -D LLAMA_BUILD_SERVER=OFF \
    -B build_release

cmake --build build_release --config Release

## build lmdb and dtlv

export OMP_LIB="-lomp"
export USEARCH_LIB="-Wl,-Bstatic -lusearch -Wl,-Bdynamic"
export LDFLAGS="-L/usr/lib -L/lib/"

cd ..
gmake clean
gmake CC=cc CXX=c++

# FreeBSD has libgomp and libomp in base

mkdir -p ../freebsd-x86_64/resources/datalevin/dtlvnative/freebsd-x86_64/
cp *.so ../freebsd-x86_64/resources/datalevin/dtlvnative/freebsd-x86_64/

cd java
java -jar ~/.m2/repository/org/bytedeco/javacpp/1.5.13/javacpp-1.5.13.jar datalevin/dtlvnative/DTLV.java

cd ../..
cp src/java/datalevin/dtlvnative/freebsd-x86_64/*.so freebsd-x86_64/resources/datalevin/dtlvnative/freebsd-x86_64/

cd freebsd-x86_64
lein clean
lein deps
lein run
lein jar
